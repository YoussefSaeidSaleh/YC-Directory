{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:turbopack": "next dev",
    "dev:sentry": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "predev": "npm run typegen",
    "prebuild": "npm run typegen",
    "typegen": "sanity schema extract --path=./sanity/extract.json && sanity typegen generate"
